	measure 'Anzahl Werke' =
			
			DISTINCTCOUNT('fakt_chpu'[source_plant_id])
		formatString: 0
		lineageTag: d4bcda73-6116-4cc9-9608-e07b77a20d7b

	measure 'Anzahl Werke Grün YTD' =
			
			COUNTROWS(
			    FILTER(
			        VALUES('fakt_chpu'[source_plant_id]),
			        [Ampel Werk YTD] = "grün"
			    )
			) + 0
		formatString: 0
		lineageTag: 72001814-4591-4c7a-be9c-d0e95e457435

	measure 'Anzahl Werke Grün VSI' =
			
			COUNTROWS(
			    FILTER(
			        VALUES('fakt_chpu'[source_plant_id]),
			        [Ampel Werk VSI] = "grün"
			    )
			) + 0
		formatString: 0
		lineageTag: a1b2c3d4-1001-4aaa-b001-000000000073

	measure 'CHPU Ist Vorwoche' =
			
			VAR _aktuelleKW = MAX('fakt_chpu'[jahr_kw])
			VAR _vorwocheKW =
			    MAXX(
			        FILTER(
			            ALL('fakt_chpu'[jahr_kw]),
			            'fakt_chpu'[jahr_kw] < _aktuelleKW
			        ),
			        'fakt_chpu'[jahr_kw]
			    )
			RETURN
			CALCULATE(
			    DIVIDE(
			        SUM('fakt_chpu'[anmin_ist]),
			        SUM('fakt_chpu'[ze_ist])
			    ),
			    'fakt_chpu'[jahr_kw] = _vorwocheKW
			)
		lineageTag: a1b2c3d4-1001-4aaa-b001-000000000050

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Trend CHPU' =
			
			VAR _diff = [CHPU Ist] - [CHPU Ist Vorwoche]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK([CHPU Ist]) || ISBLANK([CHPU Ist Vorwoche]), BLANK(),
			    _diff < -0.05, UNICHAR(9660),
			    _diff > 0.05, UNICHAR(9650),
			    UNICHAR(9654)
			)
		lineageTag: a1b2c3d4-1001-4aaa-b001-000000000051

	measure 'Management Summary Kontext' =
			
			VAR _bullet = UNICHAR(8226)
			
			RETURN
			
			_bullet & " "
			& FORMAT([Anzahl Werke Grün YTD], "0")
			& " von "
			& FORMAT([Anzahl Werke], "0")
			& " Werken YTD Ist grün"
			
			& UNICHAR(10)
			& UNICHAR(10)
			
			& _bullet & " Zielerreichung "
			& FORMAT([Ratio Ist YTD], "0.0")
			& "% YTD Ist ("
			& [Ampel Gesamt YTD]
			& " | "
			& FORMAT([Delta Ratio YTD], "+0.0;-0.0;0.0")
			& "%)"
			
			& UNICHAR(10)
			& UNICHAR(10)
			
			& _bullet & " "
			& FORMAT([Anzahl Werke Grün VSI], "0")
			& " von "
			& FORMAT([Anzahl Werke], "0")
			& " Werken VSI Ist grün"
			
			& UNICHAR(10)
			& UNICHAR(10)
			
			& _bullet & " Zielerreichung "
			& FORMAT([Ratio Ist VSI], "0.0")
			& "% VSI Ist ("
			& [Ampel Gesamt VSI]
			& " | "
			& FORMAT([Delta Ratio VSI], "+0.0;-0.0;0.0")
			& "%)"
		lineageTag: cba4f6ea-6c09-4c6a-aba8-036c0d18938d

