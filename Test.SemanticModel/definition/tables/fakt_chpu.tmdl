	measure 'Ratio Ist D' =
			
			VAR _chpu_0 = DIVIDE( [AnMin Soll ohne Ratio D], [ZE Ist] )
			VAR _chpu_ist = DIVIDE( [AnMin Ist D], [ZE Ist] )
			RETURN
			DIVIDE( _chpu_0 - _chpu_ist, _chpu_0 ) * 100
		formatString: 0.00
