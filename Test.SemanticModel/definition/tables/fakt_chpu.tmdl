	measure 'Debug Ratio Analyse' =
			
			VAR _maxJahrKW = MAX('fakt_chpu'[jahr_kw])
			VAR _jahr = INT(_maxJahrKW / 100)
			VAR _kw = MOD(_maxJahrKW, 100)
			VAR _nl = UNICHAR(10)
			VAR _sep = "═══════════════════════════════════════" & _nl
			
			VAR _ze_ist = [ZE Ist]
			VAR _ze_soll = [ZE Soll]
			VAR _anmin_ist = [AnMin Ist]
			VAR _anmin_soll = [AnMin Soll]
			VAR _anmin_soll_0 = [AnMin Soll ohne Ratio]
			
			VAR _chpu_ist = DIVIDE(_anmin_ist, _ze_ist)
			VAR _chpu_soll_ze_ist = DIVIDE(_anmin_soll, _ze_ist)
			VAR _chpu_0_ze_ist = DIVIDE(_anmin_soll_0, _ze_ist)
			
			VAR _ratio_ist_anmin = DIVIDE(_anmin_soll_0 - _anmin_ist, _anmin_soll_0)
			VAR _ratio_soll_anmin = DIVIDE(_anmin_soll_0 - _anmin_soll, _anmin_soll_0)
			
			VAR _ze_ist_ytd = [ZE Ist YTD]
			VAR _ze_soll_ytd = [ZE Soll YTD]
			VAR _anmin_ist_ytd = [AnMin Ist YTD]
			VAR _anmin_soll_ytd = [AnMin Soll YTD]
			VAR _anmin_soll_0_ytd = [AnMin Soll ohne Ratio YTD]
			
			VAR _rows = COUNTROWS('fakt_chpu')
			VAR _werke = DISTINCTCOUNT('fakt_chpu'[source_plant_id])
			
			RETURN
			
			"╔═ KONTEXT ═════════════════════════════" & _nl
			& "║ MaxJahrKW: " & FORMAT(_maxJahrKW, "0") & " (Jahr=" & FORMAT(_jahr,"0") & " KW=" & FORMAT(_kw,"0") & ")" & _nl
			& "║ Zeilen: " & FORMAT(_rows, "0") & " | Werke: " & FORMAT(_werke, "0") & _nl
			& _sep
			
			& "╔═ KW-EBENE (aggregiert) ════════════" & _nl
			& "║ ZE Ist:        " & FORMAT(_ze_ist, "#,##0.00") & _nl
			& "║ ZE Soll:       " & FORMAT(_ze_soll, "#,##0.00") & _nl
			& "║ AnMin Ist:      " & FORMAT(_anmin_ist, "#,##0.00") & _nl
			& "║ AnMin Soll:     " & FORMAT(_anmin_soll, "#,##0.00") & _nl
			& "║ AnMin Soll 0%:  " & FORMAT(_anmin_soll_0, "#,##0.00") & _nl
			& "║ CHPU Ist:       " & FORMAT(_chpu_ist, "0.0000") & _nl
			& "║ CHPU Soll:      " & FORMAT(_chpu_soll_ze_ist, "0.0000") & _nl
			& "║ CHPU 0%:        " & FORMAT(_chpu_0_ze_ist, "0.0000") & _nl
			& "║ Ratio Ist:      " & FORMAT(_ratio_ist_anmin, "0.0000") & _nl
			& "║ Ratio Soll:     " & FORMAT(_ratio_soll_anmin, "0.0000") & _nl
			& _sep
			
			& "╔═ YTD-EBENE (vorberechnete Spalten) ═" & _nl
			& "║ ZE Ist YTD:     " & FORMAT(_ze_ist_ytd, "#,##0.00") & _nl
			& "║ ZE Soll YTD:    " & FORMAT(_ze_soll_ytd, "#,##0.00") & _nl
			& "║ AnMin Ist YTD:   " & FORMAT(_anmin_ist_ytd, "#,##0.00") & _nl
			& "║ AnMin Soll YTD:  " & FORMAT(_anmin_soll_ytd, "#,##0.00") & _nl
			& "║ AnMin Soll 0% YTD:" & FORMAT(_anmin_soll_0_ytd, "#,##0.00") & _nl
			& "║ CHPU Ist YTD:    " & FORMAT([CHPU Ist YTD], "0.0000") & _nl
			& "║ Ratio Ist YTD:   " & FORMAT([Ratio Ist YTD], "0.0000") & _nl
			& "║ Ratio Soll YTD:  " & FORMAT([Ratio Soll YTD], "0.0000") & _nl
			& "╚════════════════════════════════════"
		lineageTag: 2994a7b5-8f63-46cb-b40c-8ac548620fcf

	measure 'Debug Einzelzeile v2' =
			
			VAR _nl = UNICHAR(10)
			
			VAR _rows =
			    TOPN(
			        3,
			        FILTER('fakt_chpu', 'fakt_chpu'[ze_ist] > 0),
			        'fakt_chpu'[jahr_kw], DESC,
			        'fakt_chpu'[source_plant_id], ASC
			    )
			
			RETURN
			CONCATENATEX(
			    _rows,
			    "══ " & 'fakt_chpu'[source_plant_id] & " | KW=" & 'fakt_chpu'[jahr_kw] & " ══" & _nl
			    & "anmin_ist:       " & FORMAT('fakt_chpu'[anmin_ist], "#,##0.00") & _nl
			    & "anmin_soll:      " & FORMAT('fakt_chpu'[anmin_soll], "#,##0.00") & _nl
			    & "ze_ist:          " & FORMAT('fakt_chpu'[ze_ist], "#,##0.00") & _nl
			    & "ze_soll:         " & FORMAT('fakt_chpu'[ze_soll], "#,##0.00") & _nl
			    & "──────────────────────────" & _nl
			    & "chpu_ist (Spalte):   " & FORMAT('fakt_chpu'[chpu_ist], "0.0000") & _nl
			    & "chpu_soll (Spalte):  " & FORMAT('fakt_chpu'[chpu_soll], "0.0000") & _nl
			    & "ratio_ist (Spalte):  " & FORMAT('fakt_chpu'[ratio_ist], "0.0000") & _nl
			    & "ratio_soll (Spalte): " & FORMAT('fakt_chpu'[ratio_soll], "0.0000") & _nl
			    & "──────────────────────────" & _nl
			    & "anmin_ist_ytd (Spalte):  " & FORMAT('fakt_chpu'[anmin_ist_ytd], "#,##0.00") & _nl
			    & "ze_ist_ytd (Spalte):     " & FORMAT('fakt_chpu'[ze_ist_ytd], "#,##0.00") & _nl
			    & "chpu_ist_ytd (Spalte):   " & FORMAT('fakt_chpu'[chpu_ist_ytd], "0.0000") & _nl
			    & "ratio_ist_ytd (Spalte):  " & FORMAT('fakt_chpu'[ratio_ist_ytd], "0.0000") & _nl
			    ,
			    _nl
			)
		lineageTag: a9692baa-8393-4a49-9472-08a089e8c697

