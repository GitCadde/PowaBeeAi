	/// VSI aus vorberechneten Dataflow-Spalten (temporär identisch mit YTD)
	measure 'CHPU Ist VSI' =
			
			VAR _kw = [Aktuelle JahrKW]
			VAR _ze =
			    CALCULATE(
			        SUM('fakt_chpu'[ze_ist_vsi]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			VAR _anmin =
			    CALCULATE(
			        SUM('fakt_chpu'[anmin_ist_vsi]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			RETURN
			IF( _ze = 0, BLANK(), DIVIDE( _anmin, _ze ) )
		lineageTag: a1b2c3d4-1001-4aaa-b001-000000000065

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ratio Ist VSI' =
			
			VAR _kw = [Aktuelle JahrKW]
			VAR _soll_0 =
			    CALCULATE(
			        SUM('fakt_chpu'[anmin_soll_ohne_ratio_vsi]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			VAR _ist =
			    CALCULATE(
			        SUM('fakt_chpu'[anmin_ist_vsi]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			RETURN
			DIVIDE( _soll_0 - _ist, _soll_0 ) * 100
		formatString: 0.00
		lineageTag: a1b2c3d4-1001-4aaa-b001-000000000068

	measure 'Ratio Soll VSI' =
			
			VAR _kw = [Aktuelle JahrKW]
			VAR _soll_0 =
			    CALCULATE(
			        SUM('fakt_chpu'[anmin_soll_ohne_ratio_vsi]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			VAR _soll =
			    CALCULATE(
			        SUM('fakt_chpu'[anmin_soll_vsi]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			RETURN
			DIVIDE( _soll_0 - _soll, _soll_0 ) * 100
		formatString: 0.00
		lineageTag: a1b2c3d4-1001-4aaa-b001-000000000069

	measure 'Delta Ratio VSI' =
			
