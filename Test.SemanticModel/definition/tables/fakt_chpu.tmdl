	/// YTD aus vorberechneter Dataflow-Spalte (Stand der letzten KW im Filterkontext)
	measure 'ZE Ist YTD' =
			
			VAR _kw = [Aktuelle JahrKW]
			RETURN
			CALCULATE(
			    SUM('fakt_chpu'[ze_ist_ytd]),
			    'fakt_chpu'[jahr_kw] = _kw
			)
