	measure 'Ratio Ist KST' =
			
			DIVIDE(
			    [CHPU Soll ohne Ratio KST] - [CHPU Ist KST],
			    [CHPU Soll ohne Ratio KST]
			) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000001

	measure 'Ratio Soll KST' =
			
			DIVIDE(
			    [CHPU Soll ohne Ratio KST] - [CHPU Soll KST],
			    [CHPU Soll ohne Ratio KST]
			) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000002

	measure 'Delta Ratio KST' =
			
			[Ratio Ist KST] - [Ratio Soll KST]
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000003

	measure 'Ratio Ist D KST' =
			
			VAR _chpu_0 = DIVIDE( [AnMin Soll ohne Ratio D KST], [ZE Ist KST] )
			VAR _chpu_ist = DIVIDE( [AnMin Ist D KST], [ZE Ist KST] )
			RETURN
			DIVIDE( _chpu_0 - _chpu_ist, _chpu_0 ) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000050

	measure 'Ratio Ist DI KST' =
			
			VAR _chpu_0 = DIVIDE( [AnMin Soll ohne Ratio DI KST], [ZE Ist KST] )
			VAR _chpu_ist = DIVIDE( [AnMin Ist DI KST], [ZE Ist KST] )
			RETURN
			DIVIDE( _chpu_0 - _chpu_ist, _chpu_0 ) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000051

	measure 'Ratio Ist I KST' =
			
