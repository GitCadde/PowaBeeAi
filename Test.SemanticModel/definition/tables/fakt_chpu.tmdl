	measure 'Ratio Ist D YTD' =
			
			VAR _kw = [Aktuelle JahrKW]
			VAR _soll_0 =
			    CALCULATE(
			        SUM('fakt_chpu'[anmin_soll_ohne_ratio_d_ytd]),
			        'fakt_chpu'[jahr_kw] = _kw
			    )
			VAR _ist = [AnMin Ist D YTD]
			RETURN
			DIVIDE( _soll_0 - _ist, _soll_0 ) * 100
		formatString: 0.00
