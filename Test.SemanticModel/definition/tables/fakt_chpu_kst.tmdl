	measure 'CHPU Ist KST YTD' =
			
			IF(
			    [ZE Ist KST YTD] = 0,
			    BLANK(),
			    DIVIDE( [AnMin Ist KST YTD], [ZE Ist KST YTD] )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000035

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CHPU Soll KST YTD' =
			
			IF(
