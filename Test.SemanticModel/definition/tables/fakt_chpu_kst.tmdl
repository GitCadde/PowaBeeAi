			VAR _chpu_ist = DIVIDE( [AnMin Ist I KST], [ZE Ist KST] )
			RETURN
			DIVIDE( _chpu_0 - _chpu_ist, _chpu_0 ) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000052

