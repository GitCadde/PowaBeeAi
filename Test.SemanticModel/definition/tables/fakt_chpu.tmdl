	measure 'Ampel Werk YTD' =
			
			IF(
			    ISBLANK([Ratio Ist YTD]) ||
			    ISBLANK([Ratio Soll YTD]),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        [Ratio Ist YTD] >= [Ratio Soll YTD], "grün",
			        [Ratio Ist YTD] >= 0, "gelb",
			        "rot"
			    )
			)
		lineageTag: 0c2a2198-8694-406b-ab78-7efa346265a8

	measure 'Ampel Gesamt YTD' =
			
			IF(
			    ISBLANK([Ratio Ist YTD]) ||
			    ISBLANK([Ratio Soll YTD]),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        [Ratio Ist YTD] >= [Ratio Soll YTD], "grün",
			        [Ratio Ist YTD] >= 0, "gelb",
			        "rot"
			    )
			)
		lineageTag: 37ceaf09-4f03-49ca-ba16-e8bc5181c159

