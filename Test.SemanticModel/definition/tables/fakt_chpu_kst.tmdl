	measure 'Ratio Ist KST YTD' =
			
			VAR _chpu_0 = DIVIDE( [AnMin Soll ohne Ratio KST YTD], [ZE Ist KST YTD] )
			VAR _chpu_ist = DIVIDE( [AnMin Ist KST YTD], [ZE Ist KST YTD] )
			RETURN
			DIVIDE( _chpu_0 - _chpu_ist, _chpu_0 ) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000037

	measure 'Ratio Soll KST YTD' =
			
			VAR _chpu_0 = DIVIDE( [AnMin Soll ohne Ratio KST YTD], [ZE Ist KST YTD] )
			VAR _chpu_soll = DIVIDE( [AnMin Soll KST YTD], [ZE Ist KST YTD] )
			RETURN
			DIVIDE( _chpu_0 - _chpu_soll, _chpu_0 ) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000038

	measure 'Ampel KST YTD' =
			
			IF(
			    ISBLANK([Ratio Ist KST YTD]) ||
			    ISBLANK([Ratio Soll KST YTD]),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        [Ratio Ist KST YTD] >= [Ratio Soll KST YTD], "grün",
			        [Ratio Ist KST YTD] >= 0, "gelb",
			        "rot"
			    )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000039

	measure 'Delta CHPU KST YTD' =
			
