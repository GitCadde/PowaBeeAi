table fakt_chpu_kst
	lineageTag: e763f5b3-c0cb-46f8-ad58-d17343cd8446

	measure 'Debug Rohdaten fakt_chpu_kst' =
			
			VAR _rows =
			    TOPN(
			        50,
			        'fakt_chpu_kst',
			        'fakt_chpu_kst'[jahr_kw], ASC,
			        'fakt_chpu_kst'[source_plant_id], ASC,
			        'fakt_chpu_kst'[kst_bezeichnung_kurz], ASC
			    )
			RETURN
			CONCATENATEX(
			    _rows,
			    "KW=" & COALESCE('fakt_chpu_kst'[jahr_kw], "∅")
			    & " | Werk=" & COALESCE('fakt_chpu_kst'[source_plant_id], "∅")
			    & " | KST=" & COALESCE('fakt_chpu_kst'[kst_bezeichnung_kurz], "∅")
			    & " | ZE_IST=" & FORMAT('fakt_chpu_kst'[ze_ist], "#,##0.00")
			    & " | ZE_SOLL=" & FORMAT('fakt_chpu_kst'[ze_soll], "#,##0.00")
			    & " | ANMIN_IST=" & FORMAT('fakt_chpu_kst'[anmin_ist], "#,##0.00")
			    & " | ANMIN_SOLL=" & FORMAT('fakt_chpu_kst'[anmin_soll], "#,##0.00")
			    & " | CHPU_IST=" & FORMAT('fakt_chpu_kst'[chpu_ist], "#,##0.00")
			    & " | CHPU_SOLL=" & FORMAT('fakt_chpu_kst'[chpu_soll], "#,##0.00")
			    & " | RATIO_IST=" & FORMAT('fakt_chpu_kst'[ratio_ist], "0.00%")
			    & " | RATIO_SOLL=" & FORMAT('fakt_chpu_kst'[ratio_soll], "0.00%"),
			    UNICHAR(10)
			)
		lineageTag: a3bf5248-933f-49b1-b2d1-6152f333d811

