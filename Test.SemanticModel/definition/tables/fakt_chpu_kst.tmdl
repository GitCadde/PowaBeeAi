			        'fakt_chpu_kst'[jahr_kw] <= _maxJahrKW
			    )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000031

		annotation PBI_FormatHint = {"isGeneralNumber":true}

