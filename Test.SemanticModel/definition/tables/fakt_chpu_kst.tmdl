	measure 'ZE Ist KST YTD' =
			
			VAR _maxJahrKW = MAX('fakt_chpu_kst'[jahr_kw])
			VAR _jahr = INT(_maxJahrKW / 100)
			RETURN
			CALCULATE(
			    [ZE Ist KST],
			    FILTER(
			        ALL('fakt_chpu_kst'),
			        INT('fakt_chpu_kst'[jahr_kw] / 100) = _jahr &&
			        'fakt_chpu_kst'[jahr_kw] <= _maxJahrKW
			    )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000030

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ZE Soll KST YTD' =
			
			VAR _maxJahrKW = MAX('fakt_chpu_kst'[jahr_kw])
			VAR _jahr = INT(_maxJahrKW / 100)
			RETURN
			CALCULATE(
			    [ZE Soll KST],
			    FILTER(
			        ALL('fakt_chpu_kst'),
