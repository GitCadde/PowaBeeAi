		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000024

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// YTD aus vorberechneter Dataflow-Spalte (Stand der letzten KW im Filterkontext)
	measure 'ZE Ist KST YTD' =
			
			VAR _kw = MAX('fakt_chpu_kst'[jahr_kw])
			RETURN
			CALCULATE(
			    SUM('fakt_chpu_kst'[ze_ist_ytd]),
			    'fakt_chpu_kst'[jahr_kw] = _kw
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000030

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AnMin Ist KST YTD' =
			
			VAR _kw = MAX('fakt_chpu_kst'[jahr_kw])
			RETURN
			CALCULATE(
			    SUM('fakt_chpu_kst'[anmin_ist_ytd]),
			    'fakt_chpu_kst'[jahr_kw] = _kw
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000032

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AnMin Soll KST YTD' =
			
			VAR _kw = MAX('fakt_chpu_kst'[jahr_kw])
			RETURN
			CALCULATE(
			    SUM('fakt_chpu_kst'[anmin_soll_ytd]),
			    'fakt_chpu_kst'[jahr_kw] = _kw
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000033

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AnMin Soll ohne Ratio KST YTD' =
			
			VAR _kw = MAX('fakt_chpu_kst'[jahr_kw])
			RETURN
			CALCULATE(
			    SUM('fakt_chpu_kst'[anmin_soll_ohne_ratio_ytd]),
			    'fakt_chpu_kst'[jahr_kw] = _kw
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000034

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CHPU Ist KST YTD' =
			
			IF(
			    [ZE Ist KST YTD] = 0,
			    BLANK(),
			    DIVIDE( [AnMin Ist KST YTD], [ZE Ist KST YTD] )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000035

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CHPU Soll KST YTD' =
			
			IF(
			    [ZE Ist KST YTD] = 0,
			    BLANK(),
			    DIVIDE( [AnMin Soll KST YTD], [ZE Ist KST YTD] )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000036

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ratio Ist KST YTD' =
			
			DIVIDE(
			    [AnMin Soll ohne Ratio KST YTD] - [AnMin Ist KST YTD],
			    [AnMin Soll ohne Ratio KST YTD]
			) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000037

	measure 'Ratio Soll KST YTD' =
			
			DIVIDE(
			    [AnMin Soll ohne Ratio KST YTD] - [AnMin Soll KST YTD],
			    [AnMin Soll ohne Ratio KST YTD]
			) * 100
		formatString: 0.00
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000038

	measure 'Ampel KST YTD' =
			
			IF(
			    ISBLANK([Ratio Ist KST YTD]) ||
			    ISBLANK([Ratio Soll KST YTD]),
			    BLANK(),
			    SWITCH(
			        TRUE(),
			        [Ratio Ist KST YTD] >= [Ratio Soll KST YTD], "grün",
			        [Ratio Ist KST YTD] >= 0, "gelb",
			        "rot"
			    )
			)
		lineageTag: b1b2c3d4-2001-4bbb-b001-000000000039

